DATABASE_URL="postgresql://postgres:postgres@localhost:5432/gestion_club"
PORT=3001
NEXT_PUBLIC_API_URL="http://localhost:3001/api/v1"

# Obligatoria: firma los tokens de sesión y los valida en cada request.
# Sin ella la API no puede autenticar a nadie.
AUTH_TOKEN_SECRET="change-me"
# Clave para restablecer la contraseña de un ADMIN desde el login.
ADMIN_RECOVERY_KEY="change-me-too"
STORAGE_PROVIDER="s3"
STORAGE_BUCKET="club-files"
STORAGE_REGION="us-east-1"
STORAGE_ACCESS_KEY=""
STORAGE_SECRET_KEY=""
WHATSAPP_PROVIDER="mock"
WHATSAPP_API_URL=""
WHATSAPP_API_TOKEN=""

