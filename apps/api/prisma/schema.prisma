generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MemberStatus {
  ACTIVE
  INACTIVE
}

enum MemberCategory {
  SIMPLE
  DOBLE
  ESTUDIANTE
  SOCIAL
  MENOR
  HONOR
}

enum PaymentStatus {
  REGISTERED
  VOID
}

enum CashDirection {
  IN
  OUT
}

enum IncomeType {
  MEMBERSHIP
  SALE
  DONATION
  TRAINING
  OTHER
}

enum ExpenseType {
  SUPPLIES
  SERVICES
  SALARY
  MAINTENANCE
  OTHER
}

enum MessageStatus {
  PENDING
  SENT
  FAILED
}

model Member {
  id         String            @id @default(cuid())
  matricula  String            @unique
  firstName  String
  lastName   String
  category   MemberCategory
  status     MemberStatus      @default(ACTIVE)
  grade      String?
  phone      String?
  email      String?
  notes      String?
  joinedAt   DateTime
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  charges    Charge[]
  payments   Payment[]
  messages   MessageDispatch[]

  @@index([lastName, firstName])
  @@index([status, category])
}

model MonthlyRate {
  id        String         @id @default(cuid())
  category  MemberCategory
  amount    Decimal        @db.Decimal(12, 2)
  validFrom DateTime
  validTo   DateTime?
  createdAt DateTime       @default(now())

  @@index([category, validFrom(sort: Desc)])
}

model BillingPeriod {
  id          String   @id @default(cuid())
  code        String   @unique
  label       String
  periodYear  Int
  periodMonth Int
  dueDate     DateTime
  createdAt   DateTime @default(now())
  charges     Charge[]

  @@unique([periodYear, periodMonth])
}

model Charge {
  id              String             @id @default(cuid())
  memberId        String
  billingPeriodId String
  amount          Decimal            @db.Decimal(12, 2)
  paidAmount      Decimal            @db.Decimal(12, 2) @default(0)
  dueDate         DateTime
  createdAt       DateTime           @default(now())
  member          Member             @relation(fields: [memberId], references: [id])
  billingPeriod   BillingPeriod      @relation(fields: [billingPeriodId], references: [id])
  allocations     PaymentAllocation[]

  @@unique([memberId, billingPeriodId])
  @@index([memberId])
}

model Payment {
  id          String            @id @default(cuid())
  memberId    String
  paidAt      DateTime
  periodYear  Int
  periodMonth Int
  amount      Decimal           @db.Decimal(12, 2)
  methodCode  String
  status      PaymentStatus     @default(REGISTERED)
  notes       String?
  createdAt   DateTime          @default(now())
  member      Member            @relation(fields: [memberId], references: [id])
  allocations PaymentAllocation[]

  @@index([memberId, paidAt(sort: Desc)])
  @@index([periodYear, periodMonth])
}

model PaymentAllocation {
  id        String   @id @default(cuid())
  paymentId String
  chargeId  String
  amount    Decimal  @db.Decimal(12, 2)
  createdAt DateTime @default(now())
  payment   Payment  @relation(fields: [paymentId], references: [id])
  charge    Charge   @relation(fields: [chargeId], references: [id])
}

model CashTransaction {
  id          String        @id @default(cuid())
  direction   CashDirection
  occurredAt  DateTime
  amount      Decimal       @db.Decimal(12, 2)
  methodCode  String?
  description String
  incomeType  IncomeType?
  expenseType ExpenseType?
  receiptUrl  String?
  receiptNote String?
  referenceId String?
  notes       String?
  createdAt   DateTime      @default(now())

  @@index([occurredAt, direction])
}

model WhatsappTemplate {
  id         String            @id @default(cuid())
  name       String
  code       String            @unique
  body       String
  isActive   Boolean           @default(true)
  createdAt  DateTime          @default(now())
  dispatches MessageDispatch[]
}

model MessageDispatch {
  id           String           @id @default(cuid())
  memberId     String?
  templateId   String?
  destination  String
  renderedBody String
  status       MessageStatus    @default(PENDING)
  scheduledAt  DateTime?
  sentAt       DateTime?
  errorMessage String?
  createdAt    DateTime         @default(now())
  member       Member?          @relation(fields: [memberId], references: [id])
  template     WhatsappTemplate? @relation(fields: [templateId], references: [id])

  @@index([status, scheduledAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  entityName String
  entityId   String
  action     String
  beforeData Json?
  afterData  Json?
  createdAt  DateTime @default(now())

  @@index([entityName, entityId, createdAt(sort: Desc)])
}
